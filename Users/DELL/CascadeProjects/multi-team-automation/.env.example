# MFM Corporation Multi-Team Automation System Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================
# Get these from your Supabase project settings
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=multi_team_automation
DB_USER=postgres
DB_PASSWORD=your_database_password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Password Configuration
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# Session Configuration
SESSION_SECRET_KEY=your_session_secret_key_here
SESSION_TIMEOUT_HOURS=24

# =============================================================================
# GOOGLE SERVICES CONFIGURATION (OPTIONAL)
# =============================================================================
# Google Drive Integration
GOOGLE_DRIVE_CREDENTIALS_FILE=./service-account-key.json
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Google Cloud Console
GOOGLE_PROJECT_ID=your_google_project_id
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
EMAIL_FROM=noreply@mfmcorporation.com
EMAIL_FROM_NAME=MFM Corporation Automation

# SMS Configuration (Optional)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url
SLACK_BOT_TOKEN=your_slack_bot_token

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
# Application Settings
APP_NAME=MFM Corporation Multi-Team Automation
APP_VERSION=3.0.0
DEBUG=false
ENVIRONMENT=production

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_SAMPLE_RATE=0.1

# Error Tracking
SENTRY_DSN=your_sentry_dsn_here
ENABLE_ERROR_REPORTING=true

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=your_ga_tracking_id
ENABLE_ANALYTICS=false

# =============================================================================
# TEAM CONFIGURATION
# =============================================================================
# Team Settings
MAX_CONCURRENT_WORKFLOWS=10
WORKFLOW_TIMEOUT_MINUTES=60
ERROR_RETRY_ATTEMPTS=3
ERROR_RETRY_DELAY_SECONDS=30

# Agent Settings
AGENT_HEARTBEAT_INTERVAL=30
AGENT_TIMEOUT_SECONDS=120
MAX_AGENTS_PER_TEAM=5

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
# Local Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,gif,txt,csv

# Supabase Storage
SUPABASE_BUCKET=multi-team-automation
STORAGE_PUBLIC=false
STORAGE_FILE_SIZE_LIMIT=52428800

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600
CACHE_PREFIX=mfm_automation

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Testing Configuration
TEST_DATABASE_URL=postgresql://postgres:test@localhost:5432/test_db
ENABLE_TEST_MODE=false
MOCK_EXTERNAL_APIS=true

# Development Settings
DEV_MOCK_DATA=true
DEV_SKIP_AUTH=false
DEV_LOG_SQL=false

# =============================================================================
# LEGAL TEAM CONFIGURATION
# =============================================================================
# Malaysian Legal Compliance
LEGAL_COMPLIANCE_CHECK_INTERVAL_HOURS=24
LEGAL_DOCUMENT_RETENTION_DAYS=365
ENABLE_LEGAL_AUDIT_LOG=true

# =============================================================================
# OPERATIONS MANAGER CONFIGURATION
# =============================================================================
# Agent Monitoring
AGENT_MONITORING_INTERVAL_SECONDS=60
AGENT_UTILIZATION_THRESHOLD=0.1
AGENT_PERFORMANCE_THRESHOLD=0.7
AGENT_ERROR_RATE_THRESHOLD=0.05

# Optimization Settings
OPTIMIZATION_ENABLED=true
AUTO_OPTIMIZATION_INTERVAL_MINUTES=30
WORKLOAD_REBALANCE_ENABLED=true

# =============================================================================
# REPORTING CONFIGURATION
# =============================================================================
# Report Generation
REPORT_GENERATION_SCHEDULE=0 2 * * *  # Daily at 2 AM
REPORT_RETENTION_DAYS=90
ENABLE_REAL_TIME_REPORTING=true

# Export Settings
EXPORT_FORMATS=json,csv,excel,pdf
MAX_EXPORT_RECORDS=10000

# =============================================================================
# MEETING SCHEDULER CONFIGURATION
# =============================================================================
# Calendar Integration
CALENDAR_PROVIDER=google
CALENDAR_SYNC_INTERVAL_MINUTES=15
MEETING_REMINDER_MINUTES=30
MEETING_BUFFER_MINUTES=15

# =============================================================================
# INTEGRATION SETTINGS
# =============================================================================
# MCP/LLM Integration
MCP_SERVER_URL=http://localhost:3000
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.7

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================
# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *  # Daily at 3 AM
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=./backups

# Maintenance
MAINTENANCE_WINDOW_START=02:00
MAINTENANCE_WINDOW_END=04:00
ENABLE_MAINTENANCE_MODE=false

# =============================================================================
# SECURITY POLICIES
# =============================================================================
# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=200

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Feature Toggles
ENABLE_LEGAL_TEAM=true
ENABLE_OPERATIONS_MANAGER=true
ENABLE_INNOVATION_TEAM=true
ENABLE_MARKET_INTELLIGENCE=true
ENABLE_TECHNOLOGY_TRACKING=true
ENABLE_MCP_LLM_INTEGRATION=true
ENABLE_MARKETING_TEAM=true
ENABLE_MEDIA_TEAM=true

# Experimental Features
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_BETA_FEATURES=false
ENABLE_AI_ENHANCEMENTS=false
